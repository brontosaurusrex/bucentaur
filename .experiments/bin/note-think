#!/usr/bin/env bash
set -euo pipefail

MODEL="${MODEL:-deepseek-r1}"
NOTES_DIR="${NOTES_DIR:-$HOME/notes}"

COUNT=10
DAYS=""

usage() {
cat <<'EOF'
note-think — summarize recent notes using local LLM

USAGE:
  note-think
  note-think 20
  note-think --days 30
  note-think 20 --days 7

DESCRIPTION:
  Collects recent markdown notes and asks a local Ollama model
  for a thematic overview and "what is the author thinking about"
  best-effort interpretation.

OPTIONS:
  -h, --help       Show help
  --days N         Only include notes modified within last N days

ENVIRONMENT:
  MODEL            Ollama model name (default: gemma4)
  NOTES_DIR        Notes directory (default: ~/notes)

EXAMPLES:
  note-think
  note-think 20
  note-think --days 30
  note-think 15 --days 7

EOF
}

# -------------------------
# arg parsing
# -------------------------

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
    --days)
      [[ $# -lt 2 ]] && {
        echo "--days requires a number" >&2
        exit 1
      }

      if [[ ! "$2" =~ ^[0-9]+$ ]]; then
        echo "Invalid --days value: $2" >&2
        exit 1
      fi

      DAYS="$2"
      shift 2
      ;;
    *)
      if [[ "$1" =~ ^[0-9]+$ ]]; then
        COUNT="$1"
      else
        echo "Invalid argument: $1" >&2
        exit 1
      fi
      shift
      ;;
  esac
done

# -------------------------
# build find command
# -------------------------

find_args=(
  "$NOTES_DIR"
  -maxdepth 1
  -type f
  -name '*.md'
)

if [[ -n "$DAYS" ]]; then
  find_args+=(-mtime "-$DAYS")
fi

# -------------------------
# collect files safely
# -------------------------

mapfile -t files < <(
  find "${find_args[@]}" -printf '%T@|%p\n' \
    | sort -nr \
    | head -n "$COUNT" \
    | cut -d'|' -f2-
)

if [[ ${#files[@]} -eq 0 ]]; then
  echo "No notes found"
  exit 1
fi

tmp="$(mktemp)"

for file in "${files[@]}"; do
  printf '\n\n===== NOTE: %s =====\n\n' "$(basename "$file")"
  cat "$file"
done > "$tmp"

# debug
cat "$tmp"

PROMPT='You are analyzing a collection of personal markdown notes.

Tasks:
- Identify recurring themes.
- Identify projects or interests.
- Identify what the author appears focused on recently.
- Give a best-effort overview of current thinking.
- Be concise and grounded in the text.
- Do not invent personal details.
- Do not diagnose mental state.
- Output plain text only.

Structure output like:

Themes:
- ...

Current focus:
- ...

Possible ongoing projects:
- ...

Best-effort interpretation:
...

Build static interconnected wiki using zettekasten, single file in html/css/javascript
...

'

{
  printf '%s\n\n' "$PROMPT"
  cat "$tmp"
} | ollama run "$MODEL"



rm -f "$tmp"