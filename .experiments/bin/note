#           --phony \
#           --query "$query" --reverse

#           [[ -z "$file" ]] && return
#           "$EDITOR" "$file"
# }

search_notes() {
  local selection file line

  selection=$(
    rg -m1 --no-heading --line-number --color=always "" "$NOTES_DIR" \
      | fzf --ansi \
            --delimiter : \
            --prompt="search> " \
            --preview='batcat --style=numbers --color=always {1} --highlight-line {2} 2>/dev/null || cat {1}' \
            --bind "change:reload:rg -m1 --no-heading --line-number --color=always {q} '$NOTES_DIR' || true" \
            --phony --reverse
  )

  [[ -z "$selection" ]] && return

  file="${selection%%:*}"
  line="${selection#*:}"
  line="${line%%:*}"

  "$EDITOR" "$file" "+$line"
}

new_note() {
  local title file slug

  title="${1:-note}"
  slug="$(slugify "$title")"
  file="$NOTES_DIR/$(today)-$slug.md"

  if [[ ! -f "$file" ]]; then
    cat > "$file" <<EOF
---
title: $title
date: $(today)
---
EOF
  fi

  "$EDITOR" "$file"
}

list_notes() {
  find "$NOTES_DIR" -maxdepth 1 -type f -name '*.md' -printf '%f\n' \
    | sort -r
}

cat_note() {
  local query="${1:-}"
  local file=""

  if [[ -z "$query" ]]; then
    file="$(latest_note)"
  else
    while IFS= read -r f; do
      if [[ "${f,,}" == *"${query,,}"* ]]; then
        file="$f"
        break
      fi
    done < <(find "$NOTES_DIR" -maxdepth 1 -type f -name '*.md')
  fi

  [[ -z "$file" ]] && { echo "No match found"; exit 1; }

  cat "$file"
}

open_note() {
  local query="${1:-}"
  local file=""

  # fzf mode when no query
  if [[ -z "$query" ]]; then
    open_note_fzf
    return
  fi

  while IFS= read -r f; do
    if [[ "${f,,}" == *"${query,,}"* ]]; then
      file="$f"
      break
    fi
  done < <(find "$NOTES_DIR" -maxdepth 1 -type f -name '*.md')

  [[ -z "$file" ]] && { echo "No match found"; exit 1; }

  "$EDITOR" "$file"
}

inbox_add() {
  local text="$*"
  mkdir -p "$NOTES_DIR"

  echo "- $(date '+%Y-%m-%d %H:%M') $text" >> "$INBOX"
}

usage() {
  echo "Usage:"
  echo "  note new \"title\""
  echo "  note list"
  echo "  note | note open [query]"
  echo "  note cat  [query]"
  echo "  note grep | search <query>"
  echo "  note \"quick note\" (flow.md)"
  echo "  note -h | --help"
  echo "  (pipe stands for or)"
  echo "Storage: $NOTES_DIR"
}

cmd="${1:-}"

case "$cmd" in
  new|+)
    shift
    new_note "$@"
    ;;
  list)
    list_notes
    ;;
  ""|open)
    shift || true
    open_note "$@"
    ;;
  cat)
    shift || true
    cat_note "$@"
    ;;
  grep|search)
    shift
    search_notes "$@"
    ;;
  -h|--help)
    usage
    ;;
  *)
    inbox_add "$@"
    ;;
esac