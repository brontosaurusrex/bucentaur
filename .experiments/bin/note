#!/usr/bin/env bash

# note (clean + dedupe + git sync)
# needs: fzf, rg

# written mostly by chatgpt (ai) in april 2026
# brex production

set -euo pipefail
# set -x

NOTES_DIR="${NOTES_DIR:-$HOME/notes}"
EDITOR="${EDITOR:-hx}"
export FZF_DEFAULT_OPTS="--color=fg:-1,bg:-1,hl:-1,fg+:-1,bg+:-1,hl+:-1,info:-1,prompt:-1,spinner:-1,pointer:-1,marker:-1,border:-1,preview-border:-1"

# deps
for cmd in fzf rg; do
  if ! command -v "$cmd" &>/dev/null; then
    echo "Error: $cmd is required" >&2
    exit 1
  fi
done

mkdir -p "$NOTES_DIR"

today() {
  date +"%Y-%m-%d"
}

slugify() {
  local input="${1:-}"

  input="$(echo "$input" \
    | tr '[:upper:]' '[:lower:]' \
    | tr -cd 'a-z0-9 -' \
    | tr ' ' '-' \
    | sed 's/-\+/-/g' \
    | sed 's/^-//' \
    | sed 's/-$//')"

  echo "$input"
}

# ----------------------------
# git sync (auto + manual)
# ----------------------------

note_sync() {
  local repo="$NOTES_DIR"
  local stamp="$repo/.git/.last_sync_day"
  local today_str
  local forced="${1:-}"

  # not a git repo
  if ! git -C "$repo" rev-parse --git-dir &>/dev/null 2>&1; then
    [[ "$forced" == "force" ]] && echo "note: $repo is not a git repository"
    return 0
  fi

  today_str="$(date +%Y-%m-%d)"

  # only once per day unless forced
  if [[ "$forced" != "force" ]]; then
    [[ -f "$stamp" && "$(cat "$stamp")" == "$today_str" ]] && return 0
  fi

  # skip if nothing changed
  if [[ -z "$(git -C "$repo" status --porcelain 2>/dev/null)" ]]; then
    [[ "$forced" == "force" ]] && echo "note: nothing to sync"
    echo "$today_str" > "$stamp"
    return 0
  fi

  git -C "$repo" add -A
  git -C "$repo" commit -m "notes: auto-sync $(date '+%H:%M')" &>/dev/null || true
  git -C "$repo" pull --rebase --autostash --quiet &>/dev/null || true
  git -C "$repo" push --quiet &>/dev/null || true

  echo "$today_str" > "$stamp"

  [[ "$forced" == "force" ]] && echo "note: synced"
}

# run auto-sync (will autorun when script starts, but only once)
# disabled until I understand this

#note_sync



open_note_fzf() {
  local file

  file=$(
    find "$NOTES_DIR" -maxdepth 1 -type f -name '*.md' \
      -printf '%T@ %p\n' \
    | sort -nr \
    | cut -d' ' -f2- \
    | fzf --prompt="notes> " \
          --preview="cat {}" \
          --height=80% \
          --reverse
  )

  [[ -z "$file" ]] && return
  "$EDITOR" "$file"
}

search_notes() {
  local query="${1:-}"
  local selection file line

  selection=$(
    rg -i -m1 --no-heading --line-number --color=never "$query" "$NOTES_DIR" \
      | fzf \
          --delimiter : \
          --prompt="search> " \
          --preview='cat {1}' \
          --bind "change:reload:rg -i -m1 --no-heading --line-number --color=never {q} '$NOTES_DIR' || true" \
          --phony \
          --query "$query" \
          --height=80% \
          --reverse
  )

  [[ -z "$selection" ]] && return

  file="${selection%%:*}"
  line="${selection#*:}"
  line="${line%%:*}"

  "$EDITOR" "$file" "+$line"
}

create_note() {
  local text="$*"
  local title slug file

  [[ -z "$text" ]] && return

  title="$text"

  slug="$(slugify "$text" | cut -d- -f1-5)"
  [[ -z "$slug" ]] && slug="note"

  file="$NOTES_DIR/$(today)-$slug.md"

  if [[ -f "$file" ]]; then
    "$EDITOR" "$file"
    return
  fi

  cat > "$file" <<EOF
---
title: $title
date: $(today)
---
$title
EOF

  "$EDITOR" "$file"
}

new_note() {
  local title slug file

  title="${*:-note}"

  slug="$(slugify "$title" | cut -d- -f1-5)"
  [[ -z "$slug" ]] && slug="note"

  file="$NOTES_DIR/$(today)-$slug.md"

  if [[ -f "$file" ]]; then
    "$EDITOR" "$file"
    return
  fi

  cat > "$file" <<EOF
---
title: $title
date: $(today)
---
EOF

  "$EDITOR" "$file"
}

list_notes() {
  find "$NOTES_DIR" -maxdepth 1 -type f -name '*.md' \
    -printf '%T@ %f\n' \
  | sort -nr \
  | cut -d' ' -f2-
}

latest_note() {
  find "$NOTES_DIR" -maxdepth 1 -type f -name '*.md' \
    -printf '%T@ %p\n' \
  | sort -nr \
  | head -n1 \
  | cut -d' ' -f2-
}

cat_note() {
  local query="${1:-}"
  local file=""

  if [[ -z "$query" ]]; then
    file="$(latest_note)"
  else
    while IFS= read -r f; do
      if [[ "${f,,}" == *"${query,,}"* ]]; then
        file="$f"
        break
      fi
    done < <(find "$NOTES_DIR" -maxdepth 1 -type f -name '*.md')
  fi

  [[ -z "$file" ]] && { echo "No match found"; exit 1; }

  cat "$file"
}

open_note() {
  local query="${1:-}"
  local file=""

  if [[ -z "$query" ]]; then
    open_note_fzf
    return
  fi

  while IFS= read -r f; do
    if [[ "${f,,}" == *"${query,,}"* ]]; then
      file="$f"
      break
    fi
  done < <(find "$NOTES_DIR" -maxdepth 1 -type f -name '*.md')

  [[ -z "$file" ]] && { echo "No match found"; exit 1; }

  "$EDITOR" "$file"
}

usage() {
  echo "Usage:"
  echo "  note \"text\"         → create/reopen note"
  echo "  note n \"title\"      → explicit title"
  echo "  note l              → list"
  echo "  note o              → open (fzf)"
  echo "  note c              → cat latest"
  echo "  note s              → search"
  echo "  note sync           → git sync"
  echo "  note h              → help"
  echo ""
  echo "Storage: $NOTES_DIR"
}

cmd="${1:-}"

case "$cmd" in
  new|+|n)
    shift
    new_note "$@"
    ;;
  list|l)
    list_notes
    ;;
  ""|open|o)
    shift || true
    open_note "$@"
    ;;
  cat|c)
    shift || true
    cat_note "$@"
    ;;
  grep|search|g|s)
    shift || true
    search_notes "$@"
    ;;
  sync)
    note_sync force
    ;;
  h|-h|--help)
    usage
    ;;
  *)
    create_note "$@"
    ;;
esac
