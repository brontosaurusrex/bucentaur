#!/usr/bin/env bash

# note (chatgpt 18.4.26)
# needs: fzf
# likes: batcat

set -euo pipefail
#set -x

NOTES_DIR="${NOTES_DIR:-$HOME/notes}"
INBOX="$NOTES_DIR/flow.md"
EDITOR="${EDITOR:-hx}"

mkdir -p "$NOTES_DIR"

today() {
  date +"%Y-%m-%d"
}

slugify() {
  echo "$1" \
    | tr '[:upper:]' '[:lower:]' \
    | tr -cd 'a-z0-9 -' \
    | tr ' ' '-' \
    | sed 's/-\+/-/g'
}

latest_note() {
  find "$NOTES_DIR" -maxdepth 1 -type f -name '*.md' \
    -printf '%T@ %p\n' \
    | sort -nr \
    | head -n1 \
    | cut -d' ' -f2-
}

open_note_fzf() {
  local file

  file=$(find "$NOTES_DIR" -maxdepth 1 -type f -name '*.md' \
    | sort -r \
    | fzf --prompt="notes> " \
          --preview="batcat --style=minimal --color=always {} 2>/dev/null || cat {}" \
          --height=80% \
          --reverse)

  [[ -z "$file" ]] && return

  "$EDITOR" "$file"
}

search_notes() {
  [[ -z "${1:-}" ]] && return

  local file

  file=$(grep -RIl \
    --exclude-dir=.git \
    --exclude-dir=node_modules \
    --exclude='*.swp' \
    -- "$1" "$NOTES_DIR" \
    | fzf --prompt="search> " \
          --preview="batcat --style=minimal --color=always {} 2>/dev/null || cat {}" \
          --height=80% \
          --reverse)

  [[ -z "$file" ]] && return

  "$EDITOR" "$file"
}

new_note() {
  local title file slug

  title="${1:-note}"
  slug="$(slugify "$title")"
  file="$NOTES_DIR/$(today)-$slug.md"

  if [[ ! -f "$file" ]]; then
    cat > "$file" <<EOF
---
title: $title
date: $(today)
---
EOF
  fi

  "$EDITOR" "$file"
}

list_notes() {
  find "$NOTES_DIR" -maxdepth 1 -type f -name '*.md' -printf '%f\n' \
    | sort -r
}

cat_note() {
  local query="${1:-}"
  local file=""

  if [[ -z "$query" ]]; then
    file="$(latest_note)"
  else
    while IFS= read -r f; do
      if [[ "${f,,}" == *"${query,,}"* ]]; then
        file="$f"
        break
      fi
    done < <(find "$NOTES_DIR" -maxdepth 1 -type f -name '*.md')
  fi

  [[ -z "$file" ]] && { echo "No match found"; exit 1; }

  cat "$file"
}

open_note() {
  local query="${1:-}"
  local file=""

  # fzf mode when no query
  if [[ -z "$query" ]]; then
    open_note_fzf
    return
  fi

  while IFS= read -r f; do
    if [[ "${f,,}" == *"${query,,}"* ]]; then
      file="$f"
      break
    fi
  done < <(find "$NOTES_DIR" -maxdepth 1 -type f -name '*.md')

  [[ -z "$file" ]] && { echo "No match found"; exit 1; }

  "$EDITOR" "$file"
}

inbox_add() {
  local text="$*"
  mkdir -p "$NOTES_DIR"

  echo "- $(date '+%Y-%m-%d %H:%M') $text" >> "$INBOX"
}

usage() {
  echo "Usage:"
  echo "  note new \"title\""
  echo "  note list"
  echo "  note open [query]"
  echo "  note cat  [query]"
  echo "  note grep <query>"
  echo "  note \"quick note\" (flow.md)"
  echo "  note -h | --help"
  echo ""
  echo "Storage: $NOTES_DIR"
}

cmd="${1:-}"

case "$cmd" in
  new)
    shift
    new_note "$@"
    ;;
  list)
    list_notes
    ;;
  open)
    shift || true
    open_note "$@"
    ;;
  cat)
    shift || true
    cat_note "$@"
    ;;
  grep)
    shift
    search_notes "$@"
    ;;
  ""|-h|--help)
    usage
    ;;
  *)
    inbox_add "$@"
    ;;
esac