#!/usr/bin/env bash
# findosaurus, 2026 ai update to use fdfind if available

set -euo pipefail

# --------------------------------
# choose backend
# --------------------------------

if command -v fd >/dev/null 2>&1; then
    FINDER="fd"
elif command -v fdfind >/dev/null 2>&1; then
    FINDER="fdfind"
else
    FINDER="find"
fi

# --------------------------------
# if nothing or -t then find files modified in last 3 days
# --------------------------------

if [ "${1:-}" == "-t" ] || [ "${1:-}" == "" ]; then

    if [ "$FINDER" = "find" ]; then
        find . -type f -mtime -3
    else
        "$FINDER" --type f --changed-within 3days . .
    fi

# --------------------------------
# if --exact
# --------------------------------

elif [ "$1" == "--exact" ] || [ "$1" == "-x" ]; then
    shift

    while [ $# -gt 0 ]; do

        if [ "$FINDER" = "find" ]; then
            find . -iname "$1"
        else
            "$FINDER" "^${1}$" .
        fi

        shift
    done

# --------------------------------
# if --ends
# --------------------------------

elif [ "$1" == "--ends" ] || [ "$1" == "-e" ]; then
    shift

    while [ $# -gt 0 ]; do

        if [ "$FINDER" = "find" ]; then
            find . -iname "*$1"
        else
            "$FINDER" "${1}$" .
        fi

        shift
    done

# --------------------------------
# if --starts
# --------------------------------

elif [ "$1" == "--starts" ] || [ "$1" == "-s" ]; then
    shift

    while [ $# -gt 0 ]; do

        if [ "$FINDER" = "find" ]; then
            find . -iname "$1*"
        else
            "$FINDER" "^${1}" .
        fi

        shift
    done

# --------------------------------
# if --and
# --------------------------------

elif [ "$1" == "--and" ] || [ "$1" == "-a" ]; then
    shift

    if [ "$FINDER" = "find" ]; then

        cons=()

        for arg; do
            cons+=( -iname "*$arg*" )
        done

        find . "${cons[@]}"

    else

        pattern=""

        for arg; do
            pattern+="(?=.*${arg})"
        done

        "$FINDER" "$pattern" .

    fi

# --------------------------------
# if --help
# --------------------------------

elif [ "$1" == "-h" ] || [ "$1" == "--help" ]; then

    echo "findosaurus           # last 3 days mtime"
    echo "arg1 arg2             # search for *arg1* OR *arg2*"
    echo "-x or --exact arg     # search for exact arg"
    echo "-e or --ends arg      # search for ends-with arg"
    echo "-s or --starts arg    # search for starts-with arg"
    echo "-a or --and a b       # search for *a* AND *b*"
    echo "-h or --help          # this help"
    echo ""
    echo "backend: $FINDER"

# --------------------------------
# else search from here using each argument as OR
# --------------------------------

else

    if [ "$FINDER" = "find" ]; then

        cons=()

        for arg; do
            cons+=( -o -iname "*$arg*" )
        done

        unset -v 'cons[0]'

        find . "${cons[@]}"

    else

        pattern="$(printf "%s|" "$@")"
        pattern="${pattern%|}"

        "$FINDER" "$pattern" .

    fi

fi